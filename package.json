{
  "name": "y-llm",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ],
    "overrides": {
      "prosemirror-model": "1.25.9",
      "@brett_lamy/docstream": "file:../broken-linear/blamy-notes/packages/docstream"
    }
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev:ds": "tsx src/dev/durableStreamsServer.ts",
    "dev:app": "vite dev --port 3000",
    "dev": "concurrently -k -n ds,app -c blue,green \"pnpm run dev:ds\" \"pnpm run dev:app\"",
    "build": "vite build",
    "preview": "pnpm run preview:cloudflare",
    "preview:vite": "vite preview",
    "preview:cloudflare": "pnpm run build && pnpm exec wrangler dev --config .output/server/wrangler.json",
    "deploy:cloudflare": "pnpm run build && pnpm exec wrangler deploy --config .output/server/wrangler.json",
    "cf:typegen": "pnpm exec wrangler types",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/agent",
    "test:evals": "node --env-file=.env --import tsx tests/evals/liveAgentModelEvals.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@brett_lamy/docstream": "file:../broken-linear/blamy-notes/packages/docstream",
    "@brett_lamy/docstream-editor": "file:../broken-linear/blamy-notes/packages/docstream-editor",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@durable-streams/tanstack-ai-transport": "^0.0.2",
    "@durable-streams/y-durable-streams": "^0.2.3",
    "@tanstack/ai": "^0.9.2",
    "@tanstack/ai-openai": "^0.7.2",
    "@tanstack/ai-react": "^0.7.6",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-start": "^1.167.0",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-code-block-lowlight": "^3.27.1",
    "@tiptap/extension-collaboration": "^3.27.1",
    "@tiptap/extension-collaboration-caret": "^3.27.1",
    "@tiptap/extension-list": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "^3.27.1",
    "@tiptap/y-tiptap": "^3.0.5",
    "codemirror": "^6.0.2",
    "lucide-react": "^1.21.0",
    "nitro": "npm:nitro-nightly@latest",
    "prosemirror-model": "1.25.9",
    "prosemirror-state": "1.4.4",
    "prosemirror-transform": "1.12.0",
    "prosemirror-view": "1.41.9",
    "react": "^18.3.1",
    "react-aria-components": "^1.19.0",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "y-codemirror.next": "^0.3.5",
    "y-prosemirror": "^1.3.7",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.27",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@durable-streams/server": "^0.2.3",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.20.3",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.79.0"
  },
  "dependenciesMeta": {
    "@brett_lamy/docstream": {
      "injected": true
    },
    "@brett_lamy/docstream-editor": {
      "injected": true
    }
  }
}
