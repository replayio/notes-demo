{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "collaborative-ai-editor",
  "compatibility_date": "2026-03-31",
  "compatibility_flags": [
    "nodejs_compat",
    "nodejs_compat_populate_process_env"
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "limits": {
    "cpu_ms": 30000
  },
  "vars": {
    "APP_BASE_URL": "https://collaborative-ai-editor.brett-lamy.workers.dev",
    "PUBLIC_APP_BASE_URL": "https://collaborative-ai-editor.brett-lamy.workers.dev",
    "OPENAI_MODEL": "gpt-5.4",
    "DURABLE_STREAMS_YJS_BASE_URL": "https://api.electric-sql.cloud/v1/yjs/svc-yjs-northern-gamefowl-h5s3g65b5x",
    "DURABLE_STREAMS_CHAT_BASE_URL": "https://api.electric-sql.cloud/v1/stream/svc-mathematical-cow-kzg4tmw2eh"
  },
  "secrets": {
    "required": [
      "OPENAI_API_KEY",
      "DURABLE_STREAMS_YJS_SECRET",
      "DURABLE_STREAMS_CHAT_SECRET"
    ]
  }
}
